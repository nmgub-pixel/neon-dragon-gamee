<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Neon Dragon INSANE</title>

<style>
body{
margin:0;
background:#05050f;
overflow:hidden;
font-family:Arial;
color:white;
text-align:center;
}

canvas{
display:block;
margin:auto;
}
</style>

</head>
<body>

<h1>🐉 Neon Dragon INSANE</h1>

<canvas id="game"></canvas>

<script>

const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight-80;

let mouse = {x:canvas.width/2,y:canvas.height/2};

document.addEventListener("mousemove",e=>{
mouse.x=e.clientX;
mouse.y=e.clientY;
});

document.addEventListener("touchmove",e=>{
mouse.x=e.touches[0].clientX;
mouse.y=e.touches[0].clientY;
});

function lerp(a,b,t){return a+(b-a)*t}

let segments=[];
let maxSegments=35;

for(let i=0;i<400;i++)
segments.push({x:mouse.x,y:mouse.y});

let apple={
x:Math.random()*canvas.width,
y:Math.random()*canvas.height
}

let obstacles=[];

function spawnObstacle(){

let side=Math.floor(Math.random()*4);

let x,y;

if(side==0){x=Math.random()*canvas.width;y=-50;}
if(side==1){x=Math.random()*canvas.width;y=canvas.height+50;}
if(side==2){x=-50;y=Math.random()*canvas.height;}
if(side==3){x=canvas.width+50;y=Math.random()*canvas.height;}

let angle=Math.random()*Math.PI*2;
let speed=1.5+Math.random()*2;

obstacles.push({

x,y,
vx:Math.cos(angle)*speed,
vy:Math.sin(angle)*speed,
size:15+Math.random()*20

});
}

for(let i=0;i<3;i++) spawnObstacle();

let score=0;
let gameOver=false;

function update(){

if(gameOver)return;

segments[0].x=lerp(segments[0].x,mouse.x,0.1);
segments[0].y=lerp(segments[0].y,mouse.y,0.1);

for(let i=1;i<maxSegments;i++){

let dx=segments[i-1].x-segments[i].x;
let dy=segments[i-1].y-segments[i].y;

let angle=Math.atan2(dy,dx);

segments[i].x=lerp(segments[i].x,
segments[i-1].x-Math.cos(angle)*8,0.6);

segments[i].y=lerp(segments[i].y,
segments[i-1].y-Math.sin(angle)*8,0.6);
}

let dx=segments[0].x-apple.x;
let dy=segments[0].y-apple.y;

if(Math.hypot(dx,dy)<20){

score++;
maxSegments+=5;

apple.x=Math.random()*canvas.width;
apple.y=Math.random()*canvas.height;

spawnObstacle();
}

for(let o of obstacles){

o.x+=o.vx;
o.y+=o.vy;

let dx=segments[0].x-o.x;
let dy=segments[0].y-o.y;

if(Math.hypot(dx,dy)<o.size)
gameOver=true;
}
}

function draw(){

ctx.fillStyle="#05050f";
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.fillStyle="red";
ctx.beginPath();
ctx.arc(apple.x,apple.y,10,0,Math.PI*2);
ctx.fill();

let time=Date.now()*0.005;

for(let i=maxSegments;i>0;i--){

let s=segments[i];

let size=Math.sin(i/maxSegments*Math.PI)*15;

let hue=(time*100+i*5)%360;

ctx.strokeStyle=`hsl(${hue},100%,60%)`;

ctx.beginPath();

ctx.moveTo(
s.x+Math.cos(time+i)*size,
s.y+Math.sin(time+i)*size
);

ctx.lineTo(
s.x-Math.cos(time+i)*size,
s.y-Math.sin(time+i)*size
);

ctx.stroke();
}

ctx.fillStyle="white";

ctx.beginPath();
ctx.arc(segments[0].x,segments[0].y,8,0,Math.PI*2);
ctx.fill();

ctx.fillStyle="white";
ctx.fillText("Score: "+score,20,40);

if(gameOver){

ctx.fillStyle="red";
ctx.font="60px Arial";
ctx.fillText("GAME OVER",
canvas.width/2-180,
canvas.height/2);
}
}

function loop(){

update();
draw();

requestAnimationFrame(loop);
}

loop();

</script>

</body>
</html>
